# Jira Cloud
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=replace_me
JIRA_PROJECT_KEYS=EIT,PROJ1,PROJ2
JIRA_EIT_PROJECT_KEY=EIT
JIRA_START_DATE=2024-01-01
JIRA_END_DATE=2026-03-12
SYNC_LOOKBACK_DAYS=7

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trisort
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/trisort

# Logging/runtime
LOG_LEVEL=INFO
